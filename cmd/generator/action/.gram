%start Program

%token MODULE USE LET IF ELSE RETURN IDENTIFIER
%token INTEGER FLOATING STRING CHARACTER
%token L_PAREN R_PAREN L_BRACE R_BRACE
%token ASSIGN ADD SUB MUL DIV MOD
%token EQ NEQ LT GT LE GE
%token COMMA END

%left OR
%left AND
%left EQ NEQ
%left LT GT LE GE
%left ADD SUB
%left MUL DIV MOD

Program:
    Items EOF => Module

Items:
    Item Items
  | empty

Item:
    UseStmt
  | LetStmt
  | IfStmt
  | ReturnStmt
  | ExprStmt

UseStmt:
    USE IDENTIFIER END => Use

LetStmt:
    LET IDENTIFIER ASSIGN Expr END => Let

ReturnStmt:
    RETURN Expr END => Return

IfStmt:
    IF Expr Block ELSE Block => If
  | IF Expr Block => If

Block:
    L_BRACE Items R_BRACE => Block


Expr:
    AssignExpr

AssignExpr:
    IDENTIFIER ASSIGN Expr => Assign
  | BinaryExpr


BinaryExpr:
    BinaryExpr ADD BinaryExpr => Binary
  | BinaryExpr SUB BinaryExpr => Binary
  | BinaryExpr MUL BinaryExpr => Binary
  | BinaryExpr DIV BinaryExpr => Binary
  | BinaryExpr MOD BinaryExpr => Binary

  | BinaryExpr EQ BinaryExpr  => Binary
  | BinaryExpr NEQ BinaryExpr => Binary
  | BinaryExpr LT BinaryExpr  => Binary
  | BinaryExpr GT BinaryExpr  => Binary
  | BinaryExpr LE BinaryExpr  => Binary
  | BinaryExpr GE BinaryExpr  => Binary

  | UnaryExpr


UnaryExpr:
    SUB UnaryExpr => Unary
  | ADD UnaryExpr => Unary
  | Primary


Primary:
    INTEGER => Literal
  | FLOATING => Literal
  | STRING => Literal
  | CHARACTER => Literal
  | IDENTIFIER => Ident

  | CallExpr
  | L_PAREN Expr R_PAREN


CallExpr:
    IDENTIFIER L_PAREN Args R_PAREN => Call

Args:
    Expr ArgsTail
  | empty

ArgsTail:
    COMMA Expr ArgsTail
  | empty


ExprStmt:
    Expr END => ExprStmt