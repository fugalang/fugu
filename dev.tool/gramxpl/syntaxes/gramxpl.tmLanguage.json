{
  "scopeName": "source.gramxpl",
  "patterns": [
    {
      "name": "entity.name.function.rule.gramxpl",
      "match": "^\\s*[A-Za-z_][A-Za-z0-9_]*(?=\\s*:)"
    },
    {
      "name": "keyword.operator.arrow.gramxpl",
      "match": "=>"
    },
    {
      "name": "keyword.operator.pipe.gramxpl",
      "match": "\\|"
    },
    {
      "name": "constant.language.token.gramxpl",
      "match": "\\b[A-Z_][A-Z0-9_]*\\b"
    },
    {
      "name": "variable.parameter.gramxpl",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
    },
    {
      "name": "punctuation.parenthesis.gramxpl",
      "match": "[()]"
    }
  ]
}